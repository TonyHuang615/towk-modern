{
  "kind": "collectionType",
  "collectionName": "albums",
  "info": {
    "singularName": "album",
    "pluralName": "albums",
    "displayName": "相册",
    "description": "活动相册与历史照片"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": ["恳亲大会", "文化活动", "社区服务", "青年活动", "日常活动"],
      "required": true
    },
    "date": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    }
  }
}
